{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "description": "桌面番茄钟 - 专注工作与休息计时器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
